{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Flask",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "pygeoapi.flask_app:APP",
        "FLASK_ENV": "development",
        "PYGEOAPI_CONFIG": "${workspaceFolder}/pygeoapi.config.yml",
        "PYGEOAPI_OPENAPI": "${workspaceFolder}/local.openapi.yml",
        "REDIS_HOST": "127.0.0.1",
        "REDIS_PORT": "6379",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--host=127.0.0.1", "--port=5005"],
      "jinja": true,
      // allow debugging of internal pygeoapi server code
      "justMyCode": false
    }
  ]
}
