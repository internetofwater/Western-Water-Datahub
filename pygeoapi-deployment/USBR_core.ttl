<http://vocabulary.odm2.org/variablename/activityAcidPhosphatase> skos:definition "Assay for microbial activity using acid phosphatase" ;
    skos:exactMatch "https://www.encyclopedia.com/education/dictionaries-thesauruses-pictures-and-press-releases/microbiological-assay" ;
