    skos:prefLabel "Dibenzothiophene" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/dieldrin> skos:definition "Dieldrin (C12H8Cl6O)" ;
