<http://vocabulary.odm2.org/variablename/berylium_10> skos:definition "Beryllium-10 (10Be) is a radioactive isotope of beryllium." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Beryllium-10" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
