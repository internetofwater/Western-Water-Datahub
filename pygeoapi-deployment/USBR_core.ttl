<http://lincolninst.edu/cgs/vocabularies/usbr#c_1a795f35> skos:inScheme <http://lincolninst.edu/cgs/vocabularies/usbr#conceptScheme_8257cf0e> ;
    skos:note "This group contains RISE parameters corresponding to parameterGroupId 3: Weather Data, and also incorporates parameters from usgs-sta, snotel-edr, and awdb-forecasts-edr."@en ;
    skos:prefLabel "Weather Data"@en ;
    skos:topConceptOf <http://lincolninst.edu/cgs/vocabularies/usbr#conceptScheme_8257cf0e> .

<http://lincolninst.edu/cgs/vocabularies/usbr#c_eb9ba25f> skos:inScheme <http://lincolninst.edu/cgs/vocabularies/usbr#conceptScheme_8257cf0e> ;
    skos:note "This group comprises parameters describing inorganic chemical constituents in water, including dissolved ions, nutrients, and trace metals. It contains RISE parameters from parameterGroupId 18: Inorganic Analytes."@en ;
    skos:prefLabel "Inorganic Analytes"@en ;
    skos:topConceptOf <http://lincolninst.edu/cgs/vocabularies/usbr#conceptScheme_8257cf0e> .

