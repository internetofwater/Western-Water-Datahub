<http://vocabulary.odm2.org/variablename/depthSnow> skos:definition "Depth of snow" ;
    skos:exactMatch "https://www.merriam-webster.com/dictionary/depth" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Depth, snow" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/depthUnsaturatedZone> skos:definition "Depth of the Unsaturated zone. The vadose zone, also termed the unsaturated zone, is the part of Earth between the land surface and the top of the phreatic zone, the position at which the groundwater (the water in the soil's pores) is at atmospheric pressure (\"vadose\" is from the Latin for \"shallow\"). Hence, the vadose zone extends from the top of the ground surface to the water table." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Vadose_zone" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Depth, unsaturated zone " ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/deuterium> skos:definition "Deuterium (2H), Delta D" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Deuterium" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/di_n_Butylphthalate> skos:definition "Di-n-butylphthalate (C16H22O4)" ;
