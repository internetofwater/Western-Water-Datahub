    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Di-n-octyl phthalate" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/diadinoxanthin> skos:definition "The phytoplankton pigment Diadinoxanthin" ;
