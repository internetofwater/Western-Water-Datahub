<http://vocabulary.odm2.org/variablename/evapotranspiration> skos:definition "Evapotranspiration",
        "Evapotranspiration (ET) is the sum of evaporation and plant transpiration from the Earth's land and ocean surface to the atmosphere." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Evapotranspiration" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV.",
        "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Evapotranspiration",
        "Evapotranspiration (ET)" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/evapotranspirationPotential> skos:definition "The amount of water that could be evaporated and transpired if there was sufficient water available." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
