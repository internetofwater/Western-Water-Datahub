    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Thallium, distribution coefficient" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/thalliumParticulate> skos:definition "Particulate thallium (Tl) in suspension" ;
