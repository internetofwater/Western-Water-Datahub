    skos:prefLabel "Zinc, particulate" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/zincTotal> skos:definition "Total zinc (Zn).\"Total\" indicates was measured on a whole water (unfiltered) sample." ;
