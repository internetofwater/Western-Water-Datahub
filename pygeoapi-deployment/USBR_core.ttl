    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/fluorescenceDissolvedOrganicCarbon> skos:definition "Fluorescence of dissolved organic carbon (DOC). DOC is an element specific fraction of dissolved organic matter (DOM)." ;
    skos:exactMatch "https://aslopubs.onlinelibrary.wiley.com/doi/abs/10.4319/lo.2001.46.1.0038" ;
