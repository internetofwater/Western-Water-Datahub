<http://vocabulary.odm2.org/variablename/waterDepth> skos:definition "Water depth is the distance between the water surface and the bottom of the water body at a specific location specified by the site location and offset." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Water depth" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/waterDepthAveraged> skos:definition "Water depth averaged over a channel cross-section or water body.  Averaging method to be specified in methods." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Water depth, averaged" ;
