<http://vocabulary.odm2.org/variablename/photosyntheticPhotonFluxDensity> skos:definition "The number of photons per unit time and per unit area in the wavelength band 400 to 700 nm" ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Photosynthetically_active_radiation" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Photosynthetic photon flux density (PPFD)" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/phytoplankton> skos:definition "Measurement of phytoplankton with no differentiation between species" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Phytoplankton" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/piperonylButoxide> skos:definition "Piperonyl Butoxide (C19H30O5)" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Piperonyl Butoxide" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/plagioclase> skos:definition "Plagioclase is a series of tectosilicate (framework silicate) minerals within the feldspar group. Rather than referring to a particular mineral with a specific chemical composition, plagioclase is a continuous solid solution series, more properly known as the plagioclase feldspar series (from the Ancient Greek for \"oblique fracture\", in reference to its two cleavage angles)" ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Plagioclase" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Plagioclase" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/polycyclicAromaticHydrocarbonAlkyl> skos:definition "Polycyclic aromatic hydrocarbon (PAH) having at least one alkyl sidechain (methyl, ethyl or other alkyl group) attached to the aromatic ring structure" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Polycyclic aromatic hydrocarbon, alkyl" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/polycyclicAromaticHydrocarbonParent> skos:definition "Unsubstituted (i.e., non-alkylated) polycyclic aromatic hydrocarbon (PAH)" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Polycyclic aromatic hydrocarbon, parent" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/polycyclicAromaticHydrocarbonTotal> skos:definition "total polycyclic aromatic hydrocarbon (PAH), also known as poly-aromatic hydrocarbons or polynuclear aromatic hydrocarbons" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Polycyclic aromatic hydrocarbon, total" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/porosity> skos:definition "Porosity or void fraction is a measure of the void (i.e. \"empty\") spaces in a material, and is a fraction of the volume of voids over the total volume, between 0 and 1, or as a percentage between 0 and 100%." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Porosity" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Porosity" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/position> skos:definition "Position of an element that interacts with water such as reservoir gates" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Position" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/potassiumDissolved> skos:definition "Dissolved Potassium (K)" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Potassium, dissolved" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/potassiumOxide> skos:definition "Potassium oxide (K2O), or Kalium oxide, is an ionic compound of potassium and oxygen." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Potassium_oxide" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Potassium oxide" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/potassiumTotal> skos:definition "Total Potassium (K)" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Potassium, total" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/praseodymium> skos:definition "Praseodymium is a chemical element with symbol Pr and atomic number 59. It is the third member of the lanthanide series and is traditionally considered to be one of the rare-earth metals. Praseodymium is a soft, silvery, malleable and ductile metal, valued for its magnetic, electrical, chemical, and optical properties." ;
