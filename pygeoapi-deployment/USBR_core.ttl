    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Lead, particulate" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/leadTotal> skos:definition "Total Lead (Pb). For chemical terms, total indicates an unfiltered sample." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Lead, total" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lead_208> skos:definition "Stable isotope of lead. The term stable isotope has a meaning similar to stable nuclide, but is preferably used when speaking of nuclides of a specific element. Hence, the plural form stable isotopes usually refers to isotopes of the same element. The relative abundance of such stable isotopes can be measured experimentally (isotope analysis), yielding an isotope ratio that can be used as a research tool." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Isotopes_of_lead https://en.wikipedia.org/wiki/Stable_isotope_ratio" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Lead-208" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/leafAreaIndex> skos:definition "Leaf area index (LAI) is a dimensionless quantity that characterizes plant canopies. It is defined as the one-sided green leaf area per unit ground surface area (LAI = leaf area / ground area, m2 / m2) in broadleaf canopies." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Leaf_area_index" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Leaf area index (LAI)" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/leafWetness> skos:definition "The effect of moisture settling on the surface of a leaf as a result of either condensation or rainfall." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Leaf wetness" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/length> skos:definition "Length is a measure of distance." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Length" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Length" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lightAttenuationCoefficient> skos:definition "Light attenuation coefficient" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Light attenuation coefficient" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/limoniumNashiiCoverage> skos:definition "Areal coverage of the plant Limonium nashii" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Limonium nashii Coverage" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lithiumDissolved> skos:definition "Dissolved Lithium (Li). For chemical terms, dissolved indicates a filtered sample." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Lithium, dissolved" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lithiumTotal> skos:definition "Total Lithium (Li). For chemical terms, total indicates an unfiltered sample." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Lithium, total" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/litterPlant> skos:definition "Litterfall, plant litter, leaf litter, tree litter, soil litter, or duff, is dead plant material (such as leaves, bark, needles, twigs, and cladodes) that have fallen to the ground." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Plant_litter" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Litter, plant" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/liverMass> skos:definition "Mass of the sample of liver tissue used for analyses" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Liver, mass" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/loadSuspended> skos:definition "The suspended load of a flow of fluid, such as a river, is the portion of its sediment uplifted by the fluid's flow in the process of sediment transportation. It is kept suspended by the fluid's turbulence. The suspended load generally consists of smaller particles, like clay, silt, and fine sands." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Suspended_load" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Load, suspended" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/loggerStopped> skos:definition "A categorical variable indicating that a logger was told to stop recording data. This is used for quality control." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Logger stopped" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/longitude> skos:definition "Longitude as a variable measurement or observation (Spatial reference to be designated in methods). This is distinct from the longitude of a site which is a site attribute." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Longitude" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lossOnIgnition> skos:definition "Loss on ignition is a test used in inorganic analytical chemistry, particularly in the analysis of minerals. It consists of strongly heating (\"igniting\") a sample of the material at a specified temperature, allowing volatile substances to escape, until its mass ceases to change." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Loss_on_ignition" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Loss on ignition" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lowBatteryCount> skos:definition "A counter of the number of times the battery voltage dropped below a minimum threshold" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Low battery count" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/luminousFlux> skos:definition "A measure of the total amount of visible light present" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Luminous Flux" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lutetium> skos:definition "Lutetium is a chemical element with symbol Lu and atomic number 71. It is a silvery white metal, which resists corrosion in dry air, but not in moist air. Lutetium is the last element in the lanthanide series, and it is traditionally counted among the rare earths." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Lutetium" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Lutetium" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lutetiumDissolved> skos:definition "Dissolved Lutetium (Lu). \"Dissolved \" indicates a the measurement was made on a filtered sample." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Lutetium" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Lutetium, dissolved" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/lyciumCarolinianumCoverage> skos:definition "Areal coverage of the plant Lycium carolinianum" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Lycium carolinianum Coverage" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/magnesiumDissolved> skos:definition "Dissolved Magnesium (Mg)" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Magnesium, dissolved" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

