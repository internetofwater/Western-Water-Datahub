    ns1:dateCreated "2019-08-01T21:26:38"^^xsd:dateTime ;
    ns1:description "QUDT Dimension Vectors is a vocabulary that extends QUDT Quantity Kinds with properties that support dimensional analysis. There is one dimension vector for each of the system's base quantity kinds. The vector's magnitude determines the exponent of the base dimension for the referenced quantity kind" ;
    ns1:graphTitle "QUDT Dimension Vectors Version 3.0.0",
        "QUDT Dimension Vectors Version 3.1.3",
