    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/calciumDissolved> skos:definition "Calcium is a chemical element with symbol Ca and atomic number 20. An alkaline earth metal, calcium is a reactive metal that forms a dark oxide-nitride layer when exposed to air. Its physical and chemical properties are most similar to its heavier homologues strontium and barium. It is the fifth most abundant element in Earth's crust and the third most abundant metal, after iron and aluminium. The most common calcium compound on Earth is calcium carbonate, found in limestone and the fossilised remnants of early sea life; gypsum, anhydrite, fluorite, and apatite are also sources of calcium. The name derives from Latin calx \"lime\", which was obtained from heating limestone.",
        "Dissolved Calcium (Ca)" ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Calcium" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV.",
        "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Calcium, dissolved" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/calciumOxide> skos:definition "Calcium oxide (CaO), commonly known as quicklime or burnt lime, is a widely used chemical compound." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Calcium_oxide" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Calcium oxide" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/canopyClosure> skos:definition "Crown closure is a term used in forestry. Crown closure and crown cover are two slightly different measures of the forest canopy and that determine the amount of light able to penetrate to the forest floor." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/Crown_closure" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Canopy closure" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/canopyHeight> skos:definition "Forest canopy density and height are used as variables in a number of environmental applications, such as biomass estimation, vegetation coverage, and biodiversity determination. Canopy density, or canopy cover, is the ratio of vegetation to ground as seen from the air. Canopy height measures how far above the ground the top of the canopy is. Lidar can be used to determine both of these variables." ;
    skos:exactMatch "http://desktop.arcgis.com/en/arcmap/10.3/manage-data/las-dataset/lidar-solutions-estimating-forest-density-and-height.htm" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Canopy height" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/canthaxanthin> skos:definition "The phytoplankton pigment Canthaxanthin" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Canthaxanthin" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/carbazole> skos:definition "Carbazole (C12H9N)" ;
