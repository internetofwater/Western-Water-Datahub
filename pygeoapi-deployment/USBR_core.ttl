<http://vocabulary.odm2.org/variablename/biomass> skos:definition "Mass of living biological organisms in a given area or ecosystem at a given time. If this generic term is used, the publisher should specify/qualify the species, class, etc. being measured in the method, qualifier, or other appropriate field." ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Biomass" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/biomassAboveGround> skos:definition "The biomass is the mass of living biological organisms in a given area or ecosystem at a given time on or above the surface of the ground" ;
    skos:exactMatch "https://en.wiktionary.org/wiki/aboveground https://en.wikipedia.org/wiki/Biomass_(ecology)" ;
    skos:historyNote "Wikipedia" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Biomass, above-ground" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/biomassMicrobial> skos:definition "Microbial biomass (bacteria and fungi) is a measure of the mass of the living component of soil organic matter." ;
    skos:exactMatch "http://soilquality.org.au/factsheets/microbial-biomass" ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:note "Added to support Critical Zone Observatory (CZO) data use cases. " ;
    skos:prefLabel "Biomass, microbial" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/biomassPhytoplankton> skos:definition "Total mass of phytoplankton, per unit area or volume" ;
