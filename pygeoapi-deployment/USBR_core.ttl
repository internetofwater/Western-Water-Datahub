    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Diethylene glycol" ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename> .

<http://vocabulary.odm2.org/variablename/diffractionXRay> skos:definition "X-ray crystallography (XRC) is a technique used for determining the atomic and molecular structure of a crystal, in which the crystalline structure causes a beam of incident X-rays to diffract into many specific directions." ;
    skos:exactMatch "https://en.wikipedia.org/wiki/X-ray_crystallography#X-ray_diffraction" ;
    skos:historyNote "Wikipedia" ;
