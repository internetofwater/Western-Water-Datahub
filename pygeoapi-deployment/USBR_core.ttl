<http://vocabulary.odm2.org/variablename/c_0c80dee3> rdfs:seeAlso "https://lincolninst-my.sharepoint.com/:w:/g/personal/apadilla_lincolninst_edu/ES4rlgxxsM9Pl6MD4goZdWsBdlSOAg5XJ2d0Q55WHaHbRA?e=D6BhcE"^^xsd:anyURI ;
    skos:altLabel "Height"@en,
        "Level"@en,
        "Pool Elevation"@en,
        "Reservoir Height"@en,
        "Stage"@en ;
    skos:definition "The height of the water surface in a reservoir above a specific reference point (often sea level). Usually measured in feet (e.g. acre/ft, inches)"@en ;
    skos:inScheme <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> ;
    skos:prefLabel "Elevation"@en ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> .

<http://vocabulary.odm2.org/variablename/c_5505dbb5> skos:definition "Measure of the amount of water lost to the atmosphere from surface of the reservoir.  Methods of capturing includes evaporation pans, water balance method, energy balance method, penman-montheith equation, satellite/remote sensing,  LEM .  "@en ;
    skos:editorialNote "Timestep: Daily"@en,
        "Units: Acre-ft/day"@en ;
    skos:inScheme <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> ;
    skos:prefLabel "Evaporation"@en ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> .

<http://vocabulary.odm2.org/variablename/c_85159d65> skos:inScheme <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> ;
    skos:prefLabel "Weather Data"@en ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> .

<http://vocabulary.odm2.org/variablename/c_8a7f273a> skos:altLabel "Release"@en,
        "Release to stream"@en,
        "stream release"@en ;
    skos:definition "Amount of water leaving a reservoir usually through controlled release mechanisms. Usually measured in cubic feet per second (CFS) or cubic meters per second (CMS) "@en ;
    skos:editorialNote """(from Sara Larsen) Power/Turbine release – how much of total release goes through turbine  

Spillway release – when water enters too fast water is diverted to a gate/spillway release.  Also called emergency release. 

Bypass – tubes that allow water to be bypassed 

 

Above 3 should add to total outflow 

 

Summary of inflows->outflows are typically expressed as acre-ft/day or acre-ft/month"""@en,
        "Preferred Unit: CFS, CMS (scientific)"@en,
        "Timestep: Daily"@en ;
    skos:inScheme <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> ;
    skos:prefLabel "Outflow"@en ;
    skos:topConceptOf <http://vocabulary.odm2.org/variablename/conceptScheme_7c70597b> .

