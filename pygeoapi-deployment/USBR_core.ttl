<http://vocabulary.odm2.org/variablename/wellheadPressure> skos:definition "The pressure exerted by the fluid at the wellhead or casinghead after the well has been shut off for a period of time, typically 24 hours" ;
    skos:historyNote "Originally from the CUAHSI HIS VariableNameCV.  See: http://his.cuahsi.org/mastercvreg/edit_cv11.aspx?tbl=VariableNameCV." ;
    skos:inScheme <http://vocabulary.odm2.org/variablename> ;
    skos:prefLabel "Wellhead pressure" ;
